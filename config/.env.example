# ──────────────────────────────────
# 飞书应用凭证
# 在 https://open.feishu.cn/ 创建自建应用后获取
# ──────────────────────────────────
FEISHU_APP_ID=cli_xxxxxxxxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx

# ──────────────────────────────────
# 目标飞书多维表格
# APP_TOKEN: 多维表格 URL 中 /base/ 后面那串
# TABLE_ID:  多维表格 URL 中 ?table= 后面那串（形如 tblXxx）
# 例: https://xxx.feishu.cn/base/BASC_APP_TOKEN?table=tblXXX&view=vewXXX
# ──────────────────────────────────
FEISHU_APP_TOKEN=xxxxxxxxxxxxxxxxxx
FEISHU_TABLE_ID=tblxxxxxxxxxxxxx

# ──────────────────────────────────
# 可选：自定义配置文件路径
# ──────────────────────────────────
CONFIG_PATH=config/config.yaml
